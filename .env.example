# ─────────────────────────────────────────────────────────────────────────────
# Real Estate Agent — .env.example (DÉVELOPPEMENT)
#
# Copie ce fichier en `.env.local` et renseigne les valeurs.
# Les VALEURS réelles vivent dans docs/api-config/SERVICES.md (gitignored).
# NE JAMAIS committer .env.local. Ce fichier ne contient que des NOMS de vars.
#
# Légende :  [REQUIS] boot impossible sans ·  [OPTIONNEL] mode dégradé si absent
# ─────────────────────────────────────────────────────────────────────────────

# ── DB — Supabase self-hosté gpu1 (PostgREST-only) ───────────────────────────
# GoTrue/Storage/Realtime ABSENTS. Auth = RPC verify_login (migration 0037).
NEXT_PUBLIC_SUPABASE_URL=              # [REQUIS] https://real-estate-agent-db.hearst.app
NEXT_PUBLIC_SUPABASE_ANON_KEY=        # [REQUIS] clé anon (JWT signé par SUPABASE_JWT_SECRET)
NEXT_PUBLIC_SUPABASE_PROJECT_REF=     # [OPTIONNEL] ref projet (legacy)
SUPABASE_URL=                         # [OPTIONNEL] surcharge serveur ; retombe sur NEXT_PUBLIC_SUPABASE_URL
SUPABASE_SERVICE_ROLE_KEY=            # [REQUIS] bypass RLS — SERVEUR UNIQUEMENT, jamais côté client
SUPABASE_JWT_SECRET=                  # [OPTIONNEL] secret de signature des JWT PostgREST (≥16 car.)

# ── Auth — session JWT jose custom ───────────────────────────────────────────
JWT_SECRET=                           # [REQUIS] signature des sessions (≥16 car.)
AUTH_SESSION_TTL_DAYS=30              # [OPTIONNEL] durée cookie (défaut 30j)
AUTH_CHECK_REVOCATION=true           # [OPTIONNEL] rejette les jti révoqués (revoked_sessions, migr. 0028)
AUTH_DEV_BYPASS=false                # [OPTIONNEL] DEV UNIQUEMENT — pose un JWT admin sans login. JAMAIS true en prod.

# ── Cache / Queue — Redis ────────────────────────────────────────────────────
REDIS_URL=                            # [OPTIONNEL] Railway redis://…  (runtime long)
UPSTASH_REDIS_REST_URL=               # [OPTIONNEL] Upstash REST (serverless/Vercel)
UPSTASH_REDIS_REST_TOKEN=             # [OPTIONNEL] token Upstash REST

# ── Stockage photos/docs — Cloudflare R2 (S3-compatible) ─────────────────────
R2_ENDPOINT=                          # [OPTIONNEL*] endpoint S3 du compte R2
R2_BUCKET=                            # [OPTIONNEL*] nom du bucket
R2_ACCESS_KEY_ID=                     # [OPTIONNEL*] access key
R2_SECRET_ACCESS_KEY=                 # [OPTIONNEL*] secret key
R2_PUBLIC_URL=                        # [OPTIONNEL] domaine public du bucket (URLs lecture)
# (*) les 4 R2_ vont ensemble : toutes présentes = storage actif, sinon fail-soft.

# ── Jobs asynchrones — Inngest ───────────────────────────────────────────────
INNGEST_SIGNING_KEY=                  # [OPTIONNEL] sans → chemin synchrone (fail-soft)
INNGEST_EVENT_KEY=                    # [OPTIONNEL] idem

# ── LLM ──────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=                    # [REQUIS] Claude — LLM principal (interview/estimation)
OPENAI_API_KEY=                       # [OPTIONNEL] chat Cockpit / embeddings / fallback (dégrade proprement si absent)
OPENAI_CHAT_MODEL=                    # [OPTIONNEL] modèle chat Cockpit (défaut gpt-5.4)
OPENAI_CHAT_FALLBACK_MODEL=           # [OPTIONNEL] fallback chat (défaut gpt-5.4-mini)
OPENAI_CHAT_TIMEOUT_MS=45000          # [OPTIONNEL] timeout requête chat (défaut 45000)
HYPERCLI_API_KEY=                     # [OPTIONNEL] Kimi K2.6 — chat Cockpit legacy (jamais côté client)
HYPERCLI_BASE_URL=                    # [OPTIONNEL] base URL Hypercli (drop-in openai)
MOONSHOT_API_KEY=                     # [OPTIONNEL] Moonshot direct (alt Kimi)
MOONSHOT_BASE_URL=                    # [OPTIONNEL]
KIMI_MODEL=                           # [OPTIONNEL] override modèle chat legacy
INTERVIEW_MODEL=                      # [OPTIONNEL] override modèle interview

# ── Observabilité — TOUS optionnels (mode dégradé si absents, boot jamais bloqué)
SENTRY_DSN=                           # [OPTIONNEL] erreurs serveur
NEXT_PUBLIC_SENTRY_DSN=               # [OPTIONNEL] erreurs client
LANGFUSE_PUBLIC_KEY=                  # [OPTIONNEL] traces LLM
LANGFUSE_SECRET_KEY=                  # [OPTIONNEL]
LANGFUSE_HOST=                        # [OPTIONNEL] défaut https://cloud.langfuse.com
NEXT_PUBLIC_POSTHOG_KEY=              # [OPTIONNEL] analytics produit
NEXT_PUBLIC_POSTHOG_HOST=             # [OPTIONNEL] défaut https://us.posthog.com

# ── Providers externes — TOUS optionnels (fail-soft si clé absente) ──────────
APOLLO_API_KEY=                       # [OPTIONNEL] enrichissement personnes
PDL_API_KEY=                          # [OPTIONNEL]
EXA_API_KEY=                          # [OPTIONNEL] recherche web
TAVILY_API_KEY=                       # [OPTIONNEL]
PERPLEXITY_API_KEY=                   # [OPTIONNEL]
LLAMA_CLOUD_API_KEY=                  # [OPTIONNEL] parsing documents
MOTEURIMMO_API_KEY=                   # [OPTIONNEL] listings immobiliers
APIFY_TOKEN=                          # [OPTIONNEL] scraping listings
APIFY_LISTINGS_ACTOR=                 # [OPTIONNEL]
TWILIO_ACCOUNT_SID=                   # [OPTIONNEL] SMS / WhatsApp
TWILIO_AUTH_TOKEN=                    # [OPTIONNEL]
TWILIO_SMS_FROM=                      # [OPTIONNEL]
TWILIO_WHATSAPP_FROM=                 # [OPTIONNEL]
RESEND_API_KEY=                       # [OPTIONNEL] emails
RESEND_FROM_EMAIL=                    # [OPTIONNEL] expéditeur email (contact prospection)
PROSP_CONTACT_CAP_PER_DAY=            # [OPTIONNEL] plafond contacts/jour/user/canal (défaut 30)
PROSP_CONTACT_DUP_WINDOW_SECONDS=     # [OPTIONNEL] fenêtre anti-doublon contact (défaut 86400)
COMPOSIO_API_KEY=                     # [OPTIONNEL] Gmail/Calendar
COMPOSIO_GMAIL_AUTH_CONFIG_ID=        # [OPTIONNEL]
COMPOSIO_GCAL_AUTH_CONFIG_ID=         # [OPTIONNEL]
DEEPGRAM_API_KEY=                     # [OPTIONNEL] transcription
ELEVENLABS_API_KEY=                   # [OPTIONNEL] TTS

# ── Fallback listings estimation — engine externe (best-effort) ──────────────
MYSWARMS_ENGINE_URL=                  # [OPTIONNEL] URL engine listings (fallback annonces estimation)
MYSWARMS_ENGINE_TOKEN=                # [OPTIONNEL] Bearer token engine listings

# ── Tenant / app ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3002   # [OPTIONNEL] URL publique (prod: https://real-estate-agent.vercel.app)
TENANT_ID=                            # [OPTIONNEL] tenant par défaut (sinon DEFAULT_TENANT code)
