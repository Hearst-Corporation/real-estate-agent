# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# …sauf les templates sans secret (référence de déploiement)
!.env.example
!.env.production.example

# vercel
.vercel

# claude / agents
.claude/worktrees/
.playwright-mcp/

# ui artefacts & scratch de session (screenshots d'audit/debug à la racine)
/*.png
dashboard_content.html
scan_dashboard.py
uiux-audit-*.html
docs/audit/*.html

# typescript
*.tsbuildinfo
next-env.d.ts
.supabase-db-password.tmp
.supabase-creds.tmp
docs/credentials.local.txt
docs/api-config/SERVICES.md
dist-electron/
out/
test-results/
*.dmg

# claude code session artifacts
.claude/scheduled_tasks.lock

# smart-contracts vendor & build artifacts (forge-std, cache)
docs/produit/05-smart-contracts/lib/
docs/produit/05-smart-contracts/cache/
docs/produit/05-smart-contracts/out/

# scratch / layout test files
test-layout.html

# enable-adrien backups
*.bak
.scratch/
playwright-report/
*.log
.sweep/
