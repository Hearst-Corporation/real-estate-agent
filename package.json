{
  "name": "real-estate-agent",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.5.0",
  "scripts": {
    "dev": "next dev -p 3002 --turbopack",
    "build": "next build",
    "start": "next start -p 3002",
    "lint": "eslint",
    "lint:biome": "biome lint .",
    "format": "biome format --write",
    "lint:legal": "node scripts/lint-legal.mjs",
    "lint:nav": "node scripts/lint-nav.mjs",
    "lint:secrets": "node scripts/lint-secrets.mjs",
    "lint:strings": "node scripts/lint-strings.mjs",
    "cockpit:manifest": "node scripts/gen-cockpit-manifest.mjs",
    "new:feature": "node scripts/new-feature.mjs",
    "typecheck": "tsc --noEmit",
    "check": "concurrently --kill-others-on-fail -n legal,secrets,lint,nav,strings,manifest,types,biome \"npm:lint:legal\" \"npm:lint:secrets\" \"npm:lint\" \"npm:lint:nav\" \"npm:lint:strings\" \"node scripts/gen-cockpit-manifest.mjs --check\" \"npm:typecheck\" \"npm:lint:biome\"",
    "prepare": "husky",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "electron:dev": "concurrently -k \"npm run dev\" \"wait-on http://localhost:3002 && npm run electron:start\"",
    "electron:start": "tsc -p electron && cp electron/splash.html dist-electron/splash.html && electron .",
    "electron:build": "tsc -p electron && cp electron/splash.html dist-electron/splash.html && electron-builder",
    "electron:test": "playwright test electron/__tests__",
    "seed": "node scripts/seed-crm.mjs",
    "test:e2e": "playwright test e2e",
    "electron:build:release": "tsc -p electron && cp electron/splash.html dist-electron/splash.html && electron-builder --publish never",
    "electron:publish": "tsc -p electron && cp electron/splash.html dist-electron/splash.html && electron-builder --publish always"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.1",
    "@headlessui/react": "^2.2.10",
    "@heroicons/react": "^2.2.0",
    "@sentry/nextjs": "^10.56.0",
    "@sparticuz/chromium": "^133.0.0",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.107.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "aws4fetch": "^1.0.20",
    "clsx": "^2.1.1",
    "inngest": "^4.5.0",
    "jose": "^6.2.3",
    "langfuse": "^3.38.20",
    "next": "16.2.7",
    "openai": "^6.42.0",
    "otplib": "^12.0.1",
    "playwright-core": "1.60.0",
    "posthog-js": "^1.382.0",
    "posthog-node": "^5.36.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.12.4",
    "server-only": "^0.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20.19.41",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.8",
    "concurrently": "^10.0.3",
    "electron": "^42.3.3",
    "electron-builder": "^26.8.1",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.8.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.8",
    "wait-on": "^9.0.10"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix"
    ]
  },
  "main": "dist-electron/main.js",
  "build": {
    "appId": "com.realestateagent.desktop",
    "productName": "Real estate Agent",
    "files": [
      "dist-electron/**/*",
      ".next/**/*",
      "public/**/*",
      "package.json",
      "electron/splash.html"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "electron/entitlements.mac.plist",
      "entitlementsInherit": "electron/entitlements.mac.plist",
      "notarize": true
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ]
    },
    "publish": {
      "provider": "github",
      "releaseType": "release"
    }
  }
}
