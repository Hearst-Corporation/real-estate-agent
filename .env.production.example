# ─────────────────────────────────────────────────────────────────────────────
# Real Estate Agent — .env.production.example (PRODUCTION)
#
# À renseigner dans Vercel → Project Settings → Environment Variables
# (Production + Preview). Valeurs réelles dans docs/api-config/SERVICES.md.
# Ce fichier ne liste QUE des NOMS + commentaires — aucun secret.
#
# Topologie prod : app Next sur Vercel · DB PostgREST gpu1 · R2 · Redis · Inngest.
# Détails : docs/DEPLOYMENT.md
# ─────────────────────────────────────────────────────────────────────────────

NODE_ENV=production

# ── DB — PostgREST gpu1 (real-estate-agent-db.hearst.app) [REQUIS] ───────────
NEXT_PUBLIC_SUPABASE_URL=             # https://real-estate-agent-db.hearst.app
NEXT_PUBLIC_SUPABASE_ANON_KEY=        # clé anon
SUPABASE_SERVICE_ROLE_KEY=           # service-role (bypass RLS) — SERVEUR
SUPABASE_JWT_SECRET=                 # secret de signature JWT PostgREST (≥16 car.)

# ── Auth [REQUIS] ────────────────────────────────────────────────────────────
JWT_SECRET=                           # signature sessions jose (≥16 car.)
AUTH_CHECK_REVOCATION=true           # DOIT être true en prod (logout serveur effectif)
# AUTH_DEV_BYPASS : NE PAS DÉFINIR en prod (ou =false). Le boot THROW si =true & NODE_ENV=production (lib/env.ts).

# ── Cache / Queue [REQUIS pour queues] ───────────────────────────────────────
# Sur Vercel (serverless) → préférer Upstash REST. Railway (runtime long) → REDIS_URL.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# REDIS_URL=                          # alternative Railway

# ── Stockage R2 [REQUIS — photos/documents] ──────────────────────────────────
R2_ENDPOINT=
R2_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PUBLIC_URL=

# ── Jobs — Inngest [REQUIS si jobs asynchrones utilisés] ─────────────────────
INNGEST_SIGNING_KEY=
INNGEST_EVENT_KEY=

# ── LLM [REQUIS] ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=                       # chat Cockpit / embeddings / fallback
OPENAI_CHAT_MODEL=                    # [OPTIONNEL] modèle chat Cockpit (défaut gpt-5.4)
OPENAI_CHAT_FALLBACK_MODEL=           # [OPTIONNEL] fallback chat (défaut gpt-5.4-mini)
OPENAI_CHAT_TIMEOUT_MS=45000          # [OPTIONNEL] timeout requête chat (défaut 45000)
HYPERCLI_API_KEY=                     # [OPTIONNEL] Kimi K2.6 legacy
HYPERCLI_BASE_URL=                    # [OPTIONNEL] base URL Hypercli

# ── Observabilité [OPTIONNEL — mode dégradé si absent, boot jamais bloqué] ────
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
NEXT_PUBLIC_POSTHOG_KEY=

# ── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://real-estate-agent.vercel.app

# Providers externes / webhooks (Twilio, MoteurImmo, Apify, Composio, engine listings…) :
# tous OPTIONNELS et fail-soft — voir .env.example pour la liste exhaustive.
